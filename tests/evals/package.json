{
  "name": "@your-plugin-name/evals",
  "private": true,
  "description": "Promptfoo eval harness for your-plugin-name",
  "scripts": {
    "eval": "npm run eval:example-skill && npm run eval:coverage && npm run eval:codex-compatibility",
    "eval:example-skill": "./scripts/promptfoo.sh eval --no-cache -c packages/example-skill/skill-example-skill.yaml",
    "eval:coverage": "node scripts/check-skill-eval-coverage.js",
    "eval:codex-compatibility": "node scripts/check-codex-compatibility.js",
    "view": "./scripts/promptfoo.sh view"
  },
  "dependencies": {
    "@anthropic-ai/claude-agent-sdk": "^0.2.94",
    "@anthropic-ai/claude-code": "^2.1.92",
    "promptfoo": "latest"
  },
  "overrides": {
    "@anthropic-ai/sdk": ">=0.81.0"
  }
}
