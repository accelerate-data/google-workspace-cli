#!/bin/sh
set -eu

# Block commits that contain a real Anthropic API key.

ANT_KEY_PAT="sk-ant"; ANT_KEY_PAT="${ANT_KEY_PAT}-"

staged_files=$(git diff --cached --name-only)

if [ -z "${staged_files}" ]; then
  exit 0
fi

if printf '%s\n' "$staged_files" | xargs grep -l "$ANT_KEY_PAT" 2>/dev/null | grep -q .; then
  echo "ERROR: Anthropic API key detected in staged files." >&2
  echo "Remove the key before committing." >&2
  printf '%s\n' "$staged_files" | xargs grep -l "$ANT_KEY_PAT" 2>/dev/null | while read -r f; do
    echo "  $f" >&2
  done
  exit 1
fi
